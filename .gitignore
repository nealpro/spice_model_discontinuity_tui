# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# uv and virtual environments
.venv/
.uv-cache/

# OS/editor noise
.DS_Store
.idea/
.vscode/

# SPICE and simulation artifacts: do not commit generated/raw data
*.csv
*.raw
*.txt

# Keep dependency manifest text files tracked
!requirements.txt
!requirements-*.txt

# Notes

notes/
*.json

*.md
!README.md
!docs/*.md
docs/*.typ
docs/*.pdf

.config_saved
config_examples/latest.toml

# Generated plots
spice_plots/
spice_plots_backup/
*.tar

# Testing files directory
tests/files/*
tests/mcp/*

tools/
